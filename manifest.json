{
    "id": "com.neostudio.turing"
    "name": "NS Turing",
    "version": "0.1.0"
    "main": "index.html",
    "manifestVersion": 5,
    "host": {
        "app": "PS",
        "minVersion": "23.0.0"
    },
    "entrypoints": [
        {
            "type": "panel",
            "id": "neostudio.turing.panel"
            "label": { "default": "NS Turing" },
            "minimumSize": { "width": 320, "height": 400 },
            "maximumSize": { "width": 800, "height": 2000 },
            "preferredDockedSize": { "width": 380, "height": 650 },
            "preferredFloatingSize": { "width": 420, "height": 700 },
            "icons": [
                {
                    "width": 23,
                    "height": 23,
                    "path": "icons/panel-dark.png",
                    "scale": [1, 2],
                    "theme": ["darkest", "dark", "medium"]
                },
                {
                    "width": 23,
                    "height": 23,
                    "path": "icons/panel-light.png",
                    "scale": [1, 2],
                    "theme": ["lightest", "light"]
                }
            ]
        }
    ],
    "requiredPermissions": {
        "localFileSystem": "fullAccess",
        "network": { "domains": "all" },
        "allowCodeGenerationFromStrings": true
    },
    "icons": [
        {
            "width": 23,
            "height": 23,
            "path": "icons/plugin-dark.png",
            "scale": [1, 2],
            "theme": ["darkest", "dark", "medium"],
            "species": ["generic"]
        },
        {
            "width": 23,
            "height": 23,
            "path": "icons/plugin-light.png",
            "scale": [1, 2],
            "theme": ["lightest", "light"],
            "species": ["generic"]
        }
    ]
}
